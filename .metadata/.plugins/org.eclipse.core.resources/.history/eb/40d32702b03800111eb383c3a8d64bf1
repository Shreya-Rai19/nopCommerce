package internpro.internpro;

import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.edge.EdgeDriver;
import org.testng.annotations.Test;

import junit.framework.Assert;

public class ValidateLogin {

    @Test
    public void validLoginTest() {

        // ✅ Set correct path (CHANGE THIS to your actual path)
        System.setProperty("webdriver.edge.driver", 
        "C:\\New folder\\edgedriver_win64\\msedgedriver.exe");

        WebDriver driver = new EdgeDriver();

        // Step 1: Open Website
        driver.get("https://demo.nopcommerce.com/");
        driver.manage().window().maximize();

        // Step 2: Click Login
        driver.findElement(By.linkText("Log in")).click();

        // Step 3: Enter Credentials
        driver.findElement(By.id("Email")).sendKeys("testuser@gmail.com");
        driver.findElement(By.id("Password")).sendKeys("Test@123");

        // Step 4: Click Login Button
        driver.findElement(By.xpath("//button[text()='Log in']")).click();

        // Step 5: Validation
        boolean isLoginSuccessful = driver.findElement(By.linkText("My account")).isDisplayed();
        Assert.assertTrue(isLoginSuccessful);

        // Step 6: Close Browser
        driver.quit();
    }
}